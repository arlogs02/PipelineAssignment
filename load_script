import openmeteo_requests

import pandas as pd
import requests_cache
from retry_requests import retry

# Setup the Open-Meteo API client with cache and retry on error
cache_session = requests_cache.CachedSession('.cache', expire_after = 3600)
retry_session = retry(cache_session, retries = 5, backoff_factor = 0.2)
openmeteo = openmeteo_requests.Client(session = retry_session)

# Make sure all required weather variables are listed here
# The order of variables in hourly or daily is important to assign them correctly below
url = "https://air-quality-api.open-meteo.com/v1/air-quality"
params = {
	"latitude": 38.2542,
	"longitude": -85.7594,
	"hourly": ["pm10", "pm2_5", "us_aqi", "dust", "uv_index", "ozone", "carbon_monoxide", "methane", "carbon_dioxide", "nitrogen_dioxide", "sulphur_dioxide", "aerosol_optical_depth"],
	"current": ["dust", "uv_index", "ozone", "us_aqi", "pm10", "pm2_5", "carbon_monoxide", "nitrogen_dioxide", "sulphur_dioxide", "aerosol_optical_depth"],
	"timezone": "America/New_York",
	"past_days": 31,
}
responses = openmeteo.weather_api(url, params = params)

# Process first location. Add a for-loop for multiple locations or weather models
response = responses[0]
print(f"Coordinates: {response.Latitude()}°N {response.Longitude()}°E")
print(f"Elevation: {response.Elevation()} m asl")
print(f"Timezone: {response.Timezone()}{response.TimezoneAbbreviation()}")
print(f"Timezone difference to GMT+0: {response.UtcOffsetSeconds()}s")

# Process current data. The order of variables needs to be the same as requested.
current = response.Current()
current_dust = current.Variables(0).Value()
current_uv_index = current.Variables(1).Value()
current_ozone = current.Variables(2).Value()
current_us_aqi = current.Variables(3).Value()
current_pm10 = current.Variables(4).Value()
current_pm2_5 = current.Variables(5).Value()
current_carbon_monoxide = current.Variables(6).Value()
current_nitrogen_dioxide = current.Variables(7).Value()
current_sulphur_dioxide = current.Variables(8).Value()
current_aerosol_optical_depth = current.Variables(9).Value()

print(f"\nCurrent time: {current.Time()}")
print(f"Current dust: {current_dust}")
print(f"Current uv_index: {current_uv_index}")
print(f"Current ozone: {current_ozone}")
print(f"Current us_aqi: {current_us_aqi}")
print(f"Current pm10: {current_pm10}")
print(f"Current pm2_5: {current_pm2_5}")
print(f"Current carbon_monoxide: {current_carbon_monoxide}")
print(f"Current nitrogen_dioxide: {current_nitrogen_dioxide}")
print(f"Current sulphur_dioxide: {current_sulphur_dioxide}")
print(f"Current aerosol_optical_depth: {current_aerosol_optical_depth}")

# Process hourly data. The order of variables needs to be the same as requested.
hourly = response.Hourly()
hourly_pm10 = hourly.Variables(0).ValuesAsNumpy()
hourly_pm2_5 = hourly.Variables(1).ValuesAsNumpy()
hourly_us_aqi = hourly.Variables(2).ValuesAsNumpy()
hourly_dust = hourly.Variables(3).ValuesAsNumpy()
hourly_uv_index = hourly.Variables(4).ValuesAsNumpy()
hourly_ozone = hourly.Variables(5).ValuesAsNumpy()
hourly_carbon_monoxide = hourly.Variables(6).ValuesAsNumpy()
hourly_methane = hourly.Variables(7).ValuesAsNumpy()
hourly_carbon_dioxide = hourly.Variables(8).ValuesAsNumpy()
hourly_nitrogen_dioxide = hourly.Variables(9).ValuesAsNumpy()
hourly_sulphur_dioxide = hourly.Variables(10).ValuesAsNumpy()
hourly_aerosol_optical_depth = hourly.Variables(11).ValuesAsNumpy()

hourly_data = {
	"date": pd.date_range(
		start = pd.to_datetime(hourly.Time(), unit = "s", utc = True),
		end =  pd.to_datetime(hourly.TimeEnd(), unit = "s", utc = True),
		freq = pd.Timedelta(seconds = hourly.Interval()),
		inclusive = "left"
	).tz_convert(response.Timezone().decode())
}

hourly_data["pm10"] = hourly_pm10
hourly_data["pm2_5"] = hourly_pm2_5
hourly_data["us_aqi"] = hourly_us_aqi
hourly_data["dust"] = hourly_dust
hourly_data["uv_index"] = hourly_uv_index
hourly_data["ozone"] = hourly_ozone
hourly_data["carbon_monoxide"] = hourly_carbon_monoxide
hourly_data["methane"] = hourly_methane
hourly_data["carbon_dioxide"] = hourly_carbon_dioxide
hourly_data["nitrogen_dioxide"] = hourly_nitrogen_dioxide
hourly_data["sulphur_dioxide"] = hourly_sulphur_dioxide
hourly_data["aerosol_optical_depth"] = hourly_aerosol_optical_depth

hourly_dataframe = pd.DataFrame(data = hourly_data)
print("\nHourly data\n", hourly_dataframe)
